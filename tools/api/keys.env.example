# Digital Journalist — API key registry
#
# Copy to tools/api/keys.env and fill in the keys you have.
# Anything left blank means that provider is disabled.
# Format: KEY=value  (no quotes, no spaces around =)
#
# Loaded automatically by tools/api/_common.py — every search script
# reads keys from this file (plus the process environment as fallback).
#
# Tier: F = free tier with key, K = keyless (no key needed), P = paid

# ─── KEYLESS (no key needed) ──────────────────────────────────────────────
# DuckDuckGo (via ddgs) — K — unlimited (subject to bot-throttling)
# Jina Reader — K (anonymous works; key boosts quota) — see https://jina.ai
# LangSearch — F (open source; rumored free key) — https://langsearch.com

# ─── FREE TIER (need a key) ───────────────────────────────────────────────
# Brave Search API — 2,000 queries/month — https://brave.com/search/api/
BRAVE_API_KEY=

# Tavily — 1,000 queries/month — https://tavily.com
TAVILY_API_KEY=

# Serper.dev (Google SERP) — 2,500 one-time free credits — https://serper.dev
SERPER_API_KEY=

# SerpApi (Google SERP) — 100 searches/month — https://serpapi.com
SERPAPI_API_KEY=

# Exa (neural/semantic search) — $10 free credits — https://exa.ai
EXA_API_KEY=

# Firecrawl (LLM-ready scraping + search) — 500-1000 credits/month — https://firecrawl.dev
FIRECRAWL_API_KEY=

# Google Programmable Search (Custom Search JSON API) — 100/day — https://programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Jina AI Reader (optional key for higher quota) — https://jina.ai/reader
JINA_API_KEY=

# You.com — 100/day trial — https://api.you.com
YOU_API_KEY=

# NewsAPI — 100/day developer tier — https://newsapi.org
NEWSAPI_API_KEY=

# LangSearch — free, but key recommended — https://langsearch.com
LANGSEARCH_API_KEY=

# ─── GENERATIVE AI SEARCH (need a key) ───────────────────────────────────
# Google AI Studio (Gemini) — 1,500/day on flash models — https://aistudio.google.com
GEMINI_API_KEY=

# Cohere (Command R+ with web-search connector) — trial — https://cohere.com
COHERE_API_KEY=

# ─── PAID DEEP RESEARCH ──────────────────────────────────────────────────
# Perplexity (sonar / sonar-deep-research) — pay-as-you-go — https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# OpenAI (gpt-4o-search-preview / deep research API) — pay-as-you-go — https://platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude (web search tool) — pay-as-you-go — https://console.anthropic.com
ANTHROPIC_API_KEY=

# xAI Grok (deep search) — pay-as-you-go — https://docs.x.ai
XAI_API_KEY=

# ─── POLICY OVERRIDES (optional) ─────────────────────────────────────────
# Allow paid providers without explicit --paid flag (default: 0)
ALLOW_PAID=0
# Daily $ cap on paid calls (default: 1.00). Hard stop above this.
DAILY_PAID_CAP_USD=1.00
